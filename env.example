# ========== Vite (create .env.local in project root) ==========
# Local:
# VITE_API_URL=http://localhost:5000/api
# Production example:
# VITE_API_URL=https://your-backend-domain.com/api
VITE_API_URL=http://localhost:5000/api

# Optional — override Firebase web config (otherwise built-in defaults are used).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_DATABASE_URL=

# Same secret for signing admin JWT (must match everywhere you verify admin tokens).
JWT_SECRET=use-a-long-random-string

# Optional one-time bootstrap key if you use register route for admin creation.
ADMIN_SETUP_KEY=change-me-to-a-long-random-secret
