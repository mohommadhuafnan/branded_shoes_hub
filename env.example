# ========== Vite (create .env.local in project root) ==========
# Easiest local run: `npm run dev:full` and open http://localhost:3000
# Aurora DSQL + Vercel /api (AWS): use dsql, true, or 1 — or omit in production builds (defaults to DSQL).
# Local dev with Firebase Realtime Database for catalog: set firebase, mongo, legacy, false, or 0.
VITE_DATA_BACKEND=dsql

# Optional — override Firebase web config (otherwise built-in defaults are used).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_DATABASE_URL=

# Optional: full origin if API is not same-origin (usually leave empty on Vercel).
VITE_DSQL_API_PREFIX=
# Local dev fallback when `vercel dev` starts on another port (for example 3001):
# VITE_DSQL_API_PREFIX=http://127.0.0.1:3001

# Only needed if you still use Express for something (otherwise optional).
VITE_API_URL=http://localhost:5000/api

# ========== Vercel / serverless (vercel env pull -> .env.local) ==========
# From Vercel Storage / AWS DSQL connect panel:
# AWS_ACCOUNT_ID, AWS_REGION, AWS_RESOURCE_ARN, AWS_ROLE_ARN, PGDATABASE, PGHOST, PGPORT, PGSSLMODE, PGUSER

# Same secret for signing admin JWT (must match everywhere you verify admin tokens).
JWT_SECRET=use-a-long-random-string

# One-time bootstrap: create first DSQL admin via POST /api/setup-admin (see README-DSQL.md or comments below).
# After creating admins, rotate or remove this key in Vercel.
ADMIN_SETUP_KEY=change-me-to-a-long-random-secret

# Bootstrap first DSQL admin (no Mongo). Run once while vercel dev or production is up:
# curl -X POST http://127.0.0.1:3000/api/setup-admin -H "Content-Type: application/json" -d "{\"setupKey\":\"YOUR_ADMIN_SETUP_KEY\",\"email\":\"admin@yoursite.com\",\"password\":\"YourSecurePass\",\"name\":\"Admin\"}"
#
# Then in the app: set VITE_DATA_BACKEND=dsql, run `vercel dev` + `npm run dev`, open Admin login with that email/password.
# Image uploads use /api/upload-image (no Firebase Storage). Products/orders/content use DSQL.
